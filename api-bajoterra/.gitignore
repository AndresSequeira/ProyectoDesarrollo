# Keep this repository focused on WordPress content only.
#
# This .gitignore lives in api-bajoterra, while WordPress lives in
# app/public. Everything is ignored by default, then wp-content is allowed.

*

!.gitignore
!app/
app/*
!app/public/
app/public/*
!app/public/wp-content/
!app/public/wp-content/**

# Local/generated noise inside wp-content.
app/public/wp-content/**/*.log
app/public/wp-content/**/.DS_Store
app/public/wp-content/**/Thumbs.db
